# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Analytics (required)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Search Console (optional - add verification code only)
NEXT_PUBLIC_GSC_VERIFICATION=your_verification_code

# Hotjar (optional)
NEXT_PUBLIC_HOTJAR_ID=your_hotjar_id

# Google AdSense (optional)
NEXT_PUBLIC_GOOGLE_ADSENSE_CLIENT_ID=your_adsense_client_id

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://filhocuidador.com.br
NEXT_PUBLIC_SITE_NAME=Filho Cuidador
